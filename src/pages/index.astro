---
const title = "Growing Labs";
---

<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<style>
			:root {
				--bg: #031225;
				--bg-2: #071f39;
				--primary: #19d3c5;
				--primary-hover: #11b6aa;
				--text: #ffffff;
				--muted: #c9d3df;
			}

			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			html {
				scroll-behavior: smooth;
			}

			body {
				font-family: "Inter", sans-serif;
				background:
					linear-gradient(rgba(3, 18, 37, 0.2), rgba(3, 18, 37, 0.2)),
					url("../assets/images/new_bg.png");

				background-size: cover;
				background-position: center;
				background-repeat: no-repeat;
				background-attachment: scroll;

				color: white;
				overflow-x: hidden;
			}

			.container {
				width: min(1280px, 92%);
				margin: 0 auto;
			}

			/* =========================
         NAVBAR
      ========================== */

			.navbar {
				width: 100%;
				position: fixed;
				top: 0;
				left: 0;
				z-index: 1000;
				backdrop-filter: blur(14px);
				background: rgba(3, 18, 37, 0.75);
				border-bottom: 1px solid rgba(255, 255, 255, 0.08);
			}

			.nav-content {
				height: 90px;
				display: flex;
				align-items: center;
				justify-content: space-between;
			}

			.logo {
				display: flex;
				align-items: center;
				gap: 14px;
				text-decoration: none;
			}

			.logo-icon {
				width: 150px;
				height: 150px;
				object-fit: contain;
			}

			.logo-text {
				color: white;
				font-size: 1.6rem;
				font-weight: 800;
				line-height: 1;
			}

			.logo-text span {
				color: var(--primary);
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 34px;
			}

			.nav-links a {
				color: white;
				text-decoration: none;
				font-weight: 500;
				opacity: 0.9;
				transition: 0.2s ease;
			}

			.nav-links a:hover {
				color: var(--primary);
			}

			.nav-button {
				text-decoration: none;
				background: var(--primary);
				color: #06263c;
				padding: 14px 24px;
				border-radius: 999px;
				font-weight: 700;
				transition: 0.2s ease;
			}

			.nav-button:hover {
				background: var(--primary-hover);
				transform: translateY(-2px);
			}

			/* =========================
         HAMBURGER
      ========================== */

			.hamburger {
				display: none;
			}

			.hamburger-label {
				display: none;
				width: 34px;
				cursor: pointer;
				flex-direction: column;
				gap: 6px;
			}

			.hamburger-label span {
				width: 100%;
				height: 3px;
				background: white;
				border-radius: 999px;
				transition: 0.3s ease;
			}

			/* =========================
         HERO
      ========================== */

			.hero {
				min-height: 100vh;
				display: flex;
				align-items: center;
				padding-top: 120px;
			}

			.hero-grid {
				width: 100%;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 60px;
				align-items: center;
			}

			.hero-left h1 {
				font-size: clamp(3.2rem, 7vw, 6.5rem);
				line-height: 0.95;
				font-weight: 800;
				margin-bottom: 28px;

				max-width: 620px;
			}

			.hero-left h1 span {
				color: var(--primary);
			}

			.hero-left p {
				font-size: 1.2rem;
				color: var(--muted);
				line-height: 1.7;
				max-width: 620px;
				margin-bottom: 36px;

				margin-left: 0;
			}

			.hero-left {
				padding-left: 200px;
			}
			@media (max-width: 1000px) {
				.hero-left {
					padding-left: 0;
				}
			}
			.buttons {
				display: flex;
				gap: 18px;
				flex-wrap: wrap;
			}

			.btn-primary {
				background: var(--primary);
				color: #04263f;
				padding: 16px 28px;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
				transition: 0.2s ease;
			}

			.btn-primary:hover {
				background: var(--primary-hover);
			}

			.btn-secondary {
				border: 2px solid rgba(25, 211, 197, 0.5);
				color: white;
				padding: 14px 28px;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
				transition: 0.2s ease;
			}

			.btn-secondary:hover {
				border-color: var(--primary);
				color: var(--primary);
			}

			/* =========================
         EMAIL BOX
      ========================== */

			.email-box {
				margin-top: 42px;
				max-width: 540px;
			}

			.email-box form {
				display: flex;
				gap: 14px;
			}

			.email-box input {
				flex: 1;
				border: none;
				outline: none;
				background: rgba(255, 255, 255, 0.08);
				border: 1px solid rgba(255, 255, 255, 0.1);
				padding: 18px;
				border-radius: 16px;
				color: white;
				font-size: 1rem;
			}

			.email-box input::placeholder {
				color: #cbd5e1;
			}

			.email-box button {
				border: none;
				cursor: pointer;
				background: var(--primary);
				color: #04263f;
				padding: 18px 24px;
				border-radius: 16px;
				font-weight: 700;
				transition: 0.2s ease;
			}

			.email-box button:hover {
				background: var(--primary-hover);
			}

			/* =========================
         HERO IMAGE
      ========================== */

			.hero-right {
				position: relative;
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.hero-right img {
				width: 100%;
				max-width: 680px;
				object-fit: contain;
				z-index: 2;
			}

			.glow {
				position: absolute;
				width: 500px;
				height: 500px;
				background: rgba(25, 211, 197, 0.22);
				filter: blur(120px);
				border-radius: 50%;
			}

			/* =========================
         FEATURES
      ========================== */

			.features {
				padding: 40px 0 80px;
			}

			.features-grid {
				display: grid;
				grid-template-columns: repeat(4, 1fr);

				background: white;
				border-radius: 28px;

				overflow: hidden;

				padding: 10px 0;

				box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
			}

			.feature {
				display: flex;
				align-items: center;
				justify-content: center;

				gap: 16px;

				padding: 24px 28px;

				position: relative;
			}

			.feature-icon {
				width: 100px;
				height: 100px;
				object-fit: contain;
				flex-shrink: 0;
			}

			.feature-text h3 {
				font-size: 1.05rem;
				margin-bottom: 4px;
				color: #0000;
			}

			.feature h3 {
				color: #1e293b;

				font-size: 1rem;
				font-weight: 700;

				line-height: 1.25;
			}

			.feature-text p {
				color: var(--muted);
				line-height: 1.5;
				font-size: 0.95rem;
			}

			.feature:not(:last-child)::after {
				content: "";

				position: absolute;

				right: 0;
				top: 50%;

				transform: translateY(-50%);

				width: 1px;
				height: 60%;

				background: rgba(15, 23, 42, 0.08);
			}

			/* =========================
         RESPONSIVE
      ========================== */

			@media (max-width: 1000px) {
				.hero-grid {
					grid-template-columns: 1fr;
					text-align: center;
				}

				.hero-left p {
					margin-inline: auto;
				}

				.buttons {
					justify-content: center;
				}

				.email-box {
					margin-inline: auto;
				}

				.features-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 820px) {
				.hamburger-label {
					display: flex;
				}

				.nav-links {
					position: fixed;
					top: 90px;
					left: -100%;
					width: 100%;
					height: calc(100vh - 90px);
					background: #031225;
					flex-direction: column;
					justify-content: center;
					gap: 36px;
					transition: 0.35s ease;
				}

				.nav-links a {
					font-size: 1.3rem;
				}

				.nav-button {
					display: none;
				}

				.hamburger:checked ~ .nav-links {
					left: 0;
				}

				.hamburger:checked + .hamburger-label span:nth-child(1) {
					transform: rotate(45deg) translateY(13px);
				}

				.hamburger:checked + .hamburger-label span:nth-child(2) {
					opacity: 0;
				}

				.hamburger:checked + .hamburger-label span:nth-child(3) {
					transform: rotate(-45deg) translateY(-13px);
				}
			}

			@media (max-width: 640px) {
				.hero-left h1 {
					font-size: 3.5rem;
				}

				.email-box form {
					flex-direction: column;
				}

				.features-grid {
					grid-template-columns: 1fr;
				}

				.buttons {
					flex-direction: column;
				}

				.btn-primary,
				.btn-secondary {
					width: 100%;
				}
			}

			@media (max-width: 1000px) {
				.features-grid {
					grid-template-columns: repeat(2, 1fr);
				}

				.feature:nth-child(2)::after {
					display: none;
				}
			}

			@media (max-width: 640px) {
				.features-grid {
					grid-template-columns: 1fr;
				}

				.feature::after {
					display: none;
				}

				.feature:not(:last-child) {
					border-bottom: 1px solid rgba(15, 23, 42, 0.08);
				}
			}
		</style>
	</head>

	<body>
		<!-- NAVBAR -->
		<header class="navbar">
			<div class="container nav-content">
				<a href="#" class="logo">
					<img
						src="/icons/black_bg.png"
						alt="Growing Labs"
						class="logo-icon"
					/>

					<!-- <div class="logo-text">
						Growing <br />
						<span>Labs</span>
					</div>-->
				</a>

				<input type="checkbox" id="hamburger" class="hamburger" />

				<label for="hamburger" class="hamburger-label">
					<span></span>
					<span></span>
					<span></span>
				</label>

				<nav class="nav-links">
					<a href="#">Cursos</a>
					<a href="#">Nosotros</a>
					<a href="#">Recursos</a>
					<a href="#">Blog</a>
					<a href="#">Contacto</a>
				</nav>

				<a href="#" class="nav-button"> Empieza ahora </a>
			</div>
		</header>

		<!-- HERO -->
		<section class="hero">
			<div class="container hero-grid">
				<div class="hero-left">
					<h1>
						Crece hoy. <br />
						Transforma <br />
						<span>tu futuro.</span>
					</h1>

					<p>
						Cursos prácticos de tecnología, inteligencia artificial
						y herramientas modernas para todos los niveles.
					</p>

					<div class="buttons">
						<a href="#" class="btn-primary"> Ver cursos → </a>

						<a href="#" class="btn-secondary"> Cómo funciona </a>
					</div>

					<!-- FORM -->
					<div class="email-box">
						<form
							action="https://formspree.io/f/TU_ID"
							method="POST"
						>
							<input
								type="email"
								name="email"
								placeholder="Ingresa tu correo"
								required
							/>

							<button type="submit"> Más info </button>
						</form>
					</div>
				</div>

				<!-- IMAGE -->
				<div class="hero-right">
					<div class="glow"></div>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features">
			<div class="container features-grid">
				<div class="feature">
					<img
						src="/icons/foco.png"
						alt="Aprende"
						class="feature-icon"
					/>

					<h3>Aprende a tu ritmo</h3>
				</div>

				<div class="feature">
					<img
						src="/icons/matraz.png"
						alt="Aprende"
						class="feature-icon"
					/>

					<h3>Proyectos prácticos</h3>
				</div>

				<div class="feature">
					<img
						src="/icons/personas.png"
						alt="Aprende"
						class="feature-icon"
					/>

					<h3>Comunidad activa</h3>
				</div>

				<div class="feature">
					<img
						src="/icons/certificado.png"
						alt="Aprende"
						class="feature-icon"
					/>

					<h3>Certificación incluida</h3>
				</div>
			</div>
		</section>
	</body>
</html>
